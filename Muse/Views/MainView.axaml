<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:Muse.ViewModels"
			 xmlns:ws="using:Muse.Workspace"
			 xmlns:conv="using:Muse.Converters"
			 xmlns:controls="using:Avalonia.Controls"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="Muse.Views.MainView"
			 x:Name="Root"
			 x:DataType="vm:MainViewModel">
	<Design.DataContext>
		<!-- This only sets the DataContext for the previewer in an IDE,
		to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
		<vm:MainViewModel />
	</Design.DataContext>

	<UserControl.Resources>
		<conv:InverseBooleanConverter x:Key="InverseBoolConverter" />
		<conv:ExpandSymbolConverter x:Key="ExpandSymbolConverter" />
		<!-- Local converters only; brushes are provided by ThemeResources -->

		<!-- DataTemplate for rendering a single preview table row -->
		<DataTemplate x:Key="PreviewTableRowTemplate" x:DataType="vm:PreviewTableRowViewModel">
			<StackPanel>
				<Border IsVisible="{Binding IsDivider}" Height="1" Background="#22FFFFFF" Margin="0,6" />
				<StackPanel Orientation="Horizontal" IsVisible="{Binding ShowCells}">
					<ItemsControl ItemsSource="{Binding CellViewModels}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Horizontal" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="vm:PreviewTableCellViewModel">
								<Border Background="{Binding CellBackground}" Padding="6" BorderBrush="#22FFFFFF" BorderThickness="0,0,1,0">
									<TextBlock Text="{Binding Value}" FontFamily="Consolas" FontSize="12" FontWeight="{Binding CellFontWeight}" />
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</StackPanel>
		</DataTemplate>


		<DataTemplate x:Key="PreviewBlockTemplate" x:DataType="vm:PreviewBlockViewModel">
			<StackPanel IsVisible="{Binding IsRenderable}" Spacing="6" Margin="0,0,0,10">
				<Border IsVisible="{Binding IsHeading}" Background="#18FFFFFF" CornerRadius="8" Padding="10,8">
					<TextBlock Text="{Binding Content}" FontSize="18" FontWeight="Bold" />
				</Border>
				<Border IsVisible="{Binding IsListItem}" Background="#0FFFFFFF" CornerRadius="8" Padding="10,8">
					<TextBlock Text="{Binding Content, StringFormat=• {0}}" TextWrapping="Wrap" />
				</Border>
				<Border IsVisible="{Binding IsCodeFence}" Background="#111111" CornerRadius="8" Padding="10" BorderBrush="#2B2B2B" BorderThickness="1">
					<ScrollViewer HorizontalScrollBarVisibility="Auto">
						<TextBlock Text="{Binding Content}"
								   FontFamily="Consolas"
								   Foreground="#E6E6E6"
								   TextWrapping="NoWrap" />
					</ScrollViewer>
				</Border>
				<Border IsVisible="{Binding IsTableRow}" Background="#0DFFFFFF" CornerRadius="8" Padding="10,8" BorderBrush="#22FFFFFF" BorderThickness="1">
					<StackPanel Spacing="6">
						<ItemsControl IsVisible="{Binding ShowTableGrid}" ItemsSource="{Binding TableRows}" ItemTemplate="{StaticResource PreviewTableRowTemplate}" />
						<TextBlock IsVisible="{Binding ShowAlignedTableText}" Text="{Binding TableDisplayText}" FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap" Opacity="0.75" />
						<!-- Fallback plain text preview removed -->
					</StackPanel>
				</Border>
				<TextBlock IsVisible="{Binding IsParagraph}" Text="{Binding Content}" TextWrapping="Wrap" Opacity="0.96" />
			</StackPanel>
		</DataTemplate>
	</UserControl.Resources>

	<UserControl.Styles>
	</UserControl.Styles>

	<DockPanel Margin="16" LastChildFill="True">
		<!-- 顶部工具栏 -->
		<Border DockPanel.Dock="Top"
				Padding="12,8"
				CornerRadius="8"
				Background="{StaticResource TreeBackground}"
				BorderBrush="#33FFFFFF"
				BorderThickness="1"
				Margin="0,0,0,12">
			<StackPanel Spacing="8">
				<StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
					<TextBlock Text="{Binding HeaderText}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
					<TextBlock IsVisible="{Binding HasSaveFeedback}"
							   Text="{Binding SaveFeedbackMessage}"
							   Foreground="{Binding SaveFeedbackForeground}"
							   FontSize="12"
							   VerticalAlignment="Center" />
				</StackPanel>
				<WrapPanel ItemHeight="32" ItemWidth="120">
					<Button Content="编辑模式" Command="{Binding SwitchToEditModeCommand}" />
					<Button Content="分屏模式" Command="{Binding SwitchToSplitModeCommand}" />
					<Button Content="阅读模式" Command="{Binding SwitchToReadModeCommand}" />
					<Button Content="切换分屏方向"
							Command="{Binding ToggleSplitOrientationCommand}"
							IsEnabled="{Binding IsSplitMode}" />
					<Button Content="加载工作区" Command="{Binding OpenCurrentWorkspaceCommand}" />
					<Button Content="保存文档"
							Command="{Binding SaveActiveDocumentCommand}"
							IsEnabled="{Binding CanSaveActiveDocument}" />
				</WrapPanel>
			</StackPanel>
		</Border>

		<!-- 底部调试 / 诊断控制台 -->
		<Expander DockPanel.Dock="Bottom" Header="调试与错误信息" Margin="0,12,0,0">
			<StackPanel Spacing="8">
				<TextBlock IsVisible="{Binding HasActiveDocumentConflict}"
						   Text="{Binding ActiveDocumentConflictText}"
						   Foreground="#B4009E" FontSize="12" />
				<TextBlock IsVisible="{Binding HasLatestConflictEvent}"
						   Text="{Binding LatestConflictEventMessage}"
						   Foreground="{Binding LatestConflictEventForeground}" FontSize="12" />
				<WrapPanel IsVisible="{Binding HasAnyConflictEvents}" ItemHeight="30" ItemWidth="180">
					<Button Content="{Binding ConflictLogScopeToggleText}"
							Command="{Binding ToggleConflictLogScopeCommand}"
							HorizontalAlignment="Left"
							Padding="10,4" />
					<Button Content="{Binding ConflictEventFilterToggleText}"
							Command="{Binding CycleConflictEventFilterCommand}"
							HorizontalAlignment="Left"
							Padding="10,4" />
					<Button Content="重置筛选"
							Command="{Binding ResetConflictLogFiltersCommand}"
							IsEnabled="{Binding CanResetConflictLogFilters}"
							HorizontalAlignment="Left"
							Padding="10,4" />
				</WrapPanel>
				<TextBlock IsVisible="{Binding HasAnyConflictEvents}"
						   Text="{Binding ConflictLogScopeText}"
						   Foreground="#605E5C"
						   FontSize="12" />
				<TextBlock IsVisible="{Binding HasAnyConflictEvents}"
						   Text="{Binding ConflictEventFilterText}"
						   Foreground="#605E5C"
						   FontSize="12" />
				<StackPanel Spacing="4">
					<TextBlock Text="错误详情调试导出目录（可选）"
							   Foreground="#605E5C"
							   FontSize="12" />
					<TextBox Text="{Binding DebugExportDirectory}"
							 Watermark="留空则使用当前工作区 .muse/debug"
							 MinWidth="320" />
					<Button Content="选择目录"
							Click="OnBrowseDebugExportDirectoryClick"
							HorizontalAlignment="Left"
							Padding="10,4" />
					<TextBlock Text="{Binding DebugExportDirectorySummary}"
							   Foreground="#605E5C"
							   FontSize="11"
							   TextWrapping="Wrap" />
				</StackPanel>
				<Border IsVisible="{Binding HasConflictLogPreferenceSaveError}"
						Padding="8"
						CornerRadius="8"
						Background="#14D13438"
						BorderBrush="#22D13438"
						BorderThickness="1">
					<StackPanel Spacing="6">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<TextBlock Text="偏好保存失败" Foreground="#D13438" VerticalAlignment="Center" FontSize="12" />
							<Button Content="{Binding ConflictLogPreferenceErrorToggleText}"
									Command="{Binding ToggleConflictLogPreferenceSaveErrorExpandedCommand}"
									Padding="8,4" />
							<Button Content="复制错误详情"
									Click="OnCopyErrorDetailsClick"
									Padding="8,4" />
							<Button Content="重试保存偏好"
									Command="{Binding RetryConflictLogPreferenceSaveCommand}"
									Padding="8,4" />
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6" IsVisible="{Binding HasConflictLogPreferenceNextRetry}">
								<ProgressBar Classes="retry-progress" IsIndeterminate="True" />
								<TextBlock Classes="retry-text"
										   Text="{Binding ConflictLogPreferenceNextRetrySeconds, StringFormat=将在 {0} 秒后自动重试；点击“取消重试”可停止}"
										   VerticalAlignment="Center"
										   Margin="6,0"
										   ToolTip.Tip="将在倒计时结束后自动重试；点击 '取消重试' 可停止" />
							</StackPanel>
							<Button Content="取消重试"
									Command="{Binding CancelConflictLogPreferenceRetryCommand}"
									Padding="8,4" />
						</StackPanel>
						<TextBlock IsVisible="{Binding IsConflictLogPreferenceSaveErrorExpanded}"
								   Text="{Binding ConflictLogPreferenceSaveErrorMessage}"
								   Foreground="#D13438"
								   FontSize="12"
								   TextWrapping="Wrap" />
					</StackPanel>
				</Border>
				<Button IsVisible="{Binding HasRecentConflictEvents}"
						Content="{Binding ConflictLogToggleText}"
						Command="{Binding ToggleConflictLogExpandedCommand}"
						HorizontalAlignment="Left"
						Padding="10,4" />
				<Border IsVisible="{Binding ShowExpandedConflictLogPanel}"
						Padding="8"
						CornerRadius="8"
						Background="#08FFFFFF"
						BorderBrush="#22FFFFFF"
						BorderThickness="1">
					<ItemsControl ItemsSource="{Binding RecentConflictEvents}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="vm:ConflictEventListItem">
								<TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,2" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</Border>
				<WrapPanel IsVisible="{Binding HasActiveDocumentConflict}" ItemHeight="32" ItemWidth="180">
					<Button Content="保留本地并覆盖保存"
							Command="{Binding ResolveConflictBySavingLocalCommand}"
							IsEnabled="{Binding CanResolveActiveConflict}" />
					<Button Content="丢弃本地并重载外部"
							Command="{Binding ResolveConflictByReloadingExternalCommand}"
							IsEnabled="{Binding CanResolveActiveConflict}" />
				</WrapPanel>
				<TextBlock Text="{Binding LastSaveStatus, StringFormat=最后保存状态：{0}}" Opacity="0.85" />
				<TextBlock Text="{Binding LastSavedAtDisplay, StringFormat=最后保存时间：{0}}" Opacity="0.85" />
				<TextBlock Text="{Binding WorkspaceSummary}" Opacity="0.85" TextWrapping="Wrap" />
				<Button IsVisible="{Binding IsDebugTelemetryAvailable}"
						Content="{Binding DebugTelemetryToggleText}"
						Command="{Binding ToggleDebugTelemetryExpandedCommand}"
						HorizontalAlignment="Left"
						Padding="10,4" />
				<Border IsVisible="{Binding ShowDebugTelemetryPanel}"
						Padding="8"
						CornerRadius="8"
						Background="#06FFFFFF"
						BorderBrush="#22FFFFFF"
						BorderThickness="1">
					<StackPanel Spacing="6">
						<TextBlock Text="调试诊断（仅 Debug）" FontSize="12" FontWeight="SemiBold" />
						<TextBlock Text="{Binding DebugConflictLogFlushSummary}" FontSize="12" TextWrapping="Wrap" />
						<Button Content="刷新统计"
								Command="{Binding RefreshDebugTelemetryCommand}"
								HorizontalAlignment="Left"
								Padding="10,4" />
					</StackPanel>
				</Border>
			</StackPanel>
		</Expander>

		<Grid ColumnDefinitions="280,8,*">
			<!-- 左侧工作区文件树 & 标签栏 -->
			<Border Grid.Column="0" Padding="10" CornerRadius="8" Background="{StaticResource TreeBackground}" BorderBrush="#2FFFFFFF" BorderThickness="1">
				<Grid RowDefinitions="Auto,*,Auto,Auto">
					<TextBlock Grid.Row="0" Text="工作区文件" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
					<ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto">
						<ItemsControl ItemsSource="{Binding FileTree}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:FileTreeNodeViewModel">
									<StackPanel Classes="file-row">
										<StackPanel Orientation="Horizontal" Spacing="6">
											<Button Content="{Binding IsExpanded, Converter={StaticResource ExpandSymbolConverter}}" Command="{Binding ToggleExpandedCommand}" IsVisible="{Binding IsDirectory}" Padding="4" />
											<TextBlock Text="{Binding IconGlyph}" FontFamily="{StaticResource IconFontFamily}" Foreground="{StaticResource IconForeground}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="{StaticResource IconLargeSize}" />
											<TextBlock Text="{Binding Name}" Foreground="{StaticResource TreeForeground}" />
											<Button Command="{Binding OpenCommand}" Padding="6,2" Margin="6,0">
												<TextBlock Text="{StaticResource OpenGlyph}"
														   FontFamily="{StaticResource IconFontFamily}"
														   FontSize="{StaticResource IconSmallSize}"
														   Foreground="{StaticResource IconForeground}" />
											</Button>
										</StackPanel>
										<ItemsControl ItemsSource="{Binding Children}" Margin="8,4,0,0" IsVisible="{Binding IsExpanded}">
											<ItemsControl.ItemTemplate>
												<DataTemplate x:DataType="vm:FileTreeNodeViewModel">
													<StackPanel Orientation="Horizontal" Spacing="6" Classes="file-row">
														<TextBlock Text="{Binding IconGlyph}" FontFamily="{StaticResource IconFontFamily}" Foreground="{StaticResource IconForeground}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="{StaticResource IconSmallSize}" />
														<TextBlock Text="{Binding Name}" Foreground="{StaticResource TreeForeground}" />
														<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
															<TextBlock Text="{Binding IsExpanded, Converter={StaticResource ExpandSymbolConverter}}" FontSize="12" VerticalAlignment="Center" IsVisible="{Binding IsDirectory}" Margin="6,0" />
															<Button Command="{Binding OpenCommand}" Padding="6,2" Margin="6,0">
																<TextBlock Text="{StaticResource OpenGlyph}"
																		   FontFamily="{StaticResource IconFontFamily}"
																		   FontSize="{StaticResource IconSmallSize}"
																		   Foreground="{StaticResource IconForeground}" />
															</Button>
														</StackPanel>
													</StackPanel>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
					<TextBlock Grid.Row="2" Text="打开标签" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,8" />
					<ScrollViewer Grid.Row="3" MaxHeight="250" HorizontalScrollBarVisibility="Auto">
						<ItemsControl ItemsSource="{Binding WorkspaceTabs}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:WorkspaceTabViewModel">
									<StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
										<Button Command="{Binding DataContext.ActivateTabCommand, ElementName=Root}"
												CommandParameter="{Binding DocumentId}"
												Background="Transparent"
												BorderThickness="0"
												Padding="0"
												Cursor="Hand">
											<TextBlock Text="{Binding FileName}" ToolTip.Tip="{Binding FilePath}" TextTrimming="CharacterEllipsis" Width="120" Foreground="{StaticResource TreeForeground}" VerticalAlignment="Center" />
										</Button>
										<TextBlock Text="{StaticResource TabDirtyGlyph}"
												   Foreground="{StaticResource TabDirtyForeground}"
												   IsVisible="{Binding IsDirty}"
												   FontFamily="{StaticResource IconFontFamily}"
												   FontSize="10"
												   VerticalAlignment="Center"
												   ToolTip.Tip="未保存" />
										<TextBlock Text="{StaticResource TabConflictGlyph}"
												   Foreground="{StaticResource TabConflictForeground}"
												   IsVisible="{Binding HasExternalConflict}"
												   FontFamily="{StaticResource IconFontFamily}"
												   FontSize="10"
												   VerticalAlignment="Center"
												   ToolTip.Tip="存在外部冲突" />
										<Button Command="{Binding DataContext.CloseTabCommand, ElementName=Root}"
												CommandParameter="{Binding DocumentId}"
												Background="Transparent"
												BorderThickness="0"
												Padding="4"
												CornerRadius="4"
												Cursor="Hand"
												ToolTip.Tip="关闭标签">
											<TextBlock Text="{StaticResource TabCloseGlyph}"
													   FontFamily="{StaticResource IconFontFamily}"
													   FontSize="10" />
										</Button>
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</Grid>
			</Border>
			<!-- 中间分隔 -->
			<Border Grid.Column="1" Background="Transparent" Width="8" />
			<!-- 现有主内容放到第2列 -->
			<Border Grid.Column="2">
				<StackPanel Spacing="8">
					<!-- 顶部横向标签条（工作区多标签） -->
					<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="40">
						<ItemsControl ItemsSource="{Binding WorkspaceTabs}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Orientation="Horizontal" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.Styles>
								<Style Selector="Border.tab">
									<Setter Property="Background" Value="#1AFFFFFF" />
									<Setter Property="BorderBrush" Value="#2FFFFFFF" />
								</Style>
								<Style Selector="Border.tab.active">
									<Setter Property="Background" Value="#3FFFFFFF" />
									<Setter Property="BorderBrush" Value="#4FFFFFFF" />
								</Style>
								<Style Selector="Border.tab:pointerover">
									<Setter Property="Background" Value="#2AFFFFFF" />
								</Style>
							</ItemsControl.Styles>
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:WorkspaceTabViewModel">
									<Border Classes="tab" Classes.active="{Binding IsActive}" CornerRadius="6,6,0,0" Margin="0,0,4,0" Padding="8,4" BorderThickness="1,1,1,0">
										<StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
											<TextBlock Text="{StaticResource TabDirtyGlyph}"
													   Foreground="{StaticResource TabDirtyForeground}"
													   IsVisible="{Binding IsDirty}"
													   FontFamily="{StaticResource IconFontFamily}"
													   FontSize="10"
													   VerticalAlignment="Center"
													   ToolTip.Tip="未保存" />
											<TextBlock Text="{StaticResource TabConflictGlyph}"
													   Foreground="{StaticResource TabConflictForeground}"
													   IsVisible="{Binding HasExternalConflict}"
													   FontFamily="{StaticResource IconFontFamily}"
													   FontSize="10"
													   VerticalAlignment="Center"
													   ToolTip.Tip="存在外部冲突" />
											<Button Command="{Binding DataContext.ActivateTabCommand, ElementName=Root}"
													CommandParameter="{Binding DocumentId}"
													Background="Transparent"
													BorderThickness="0"
													Padding="0"
													Cursor="Hand">
												<TextBlock Text="{Binding FileName}" ToolTip.Tip="{Binding FilePath}" TextTrimming="CharacterEllipsis" MaxWidth="140" Foreground="{StaticResource TreeForeground}" VerticalAlignment="Center" />
											</Button>
											<Button Command="{Binding DataContext.CloseTabCommand, ElementName=Root}"
													CommandParameter="{Binding DocumentId}"
													Background="Transparent"
													BorderThickness="0"
													Padding="4"
													CornerRadius="4"
													Cursor="Hand"
													ToolTip.Tip="关闭标签">
												<TextBlock Text="{StaticResource TabCloseGlyph}" FontFamily="{StaticResource IconFontFamily}" FontSize="10" />
											</Button>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>

					<!-- 主面板（编辑/分屏/阅读） -->
					<Panel>
						<Border IsVisible="{Binding IsEditMode}"
								Padding="16"
								CornerRadius="12"
								Background="#0FFFFFFF"
								BorderBrush="#2FFFFFFF"
								BorderThickness="1">
							<Grid RowDefinitions="Auto, *">
								<TextBlock Grid.Row="0" Text="编辑模式：所见即所得（骨架）" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
								<ScrollViewer Grid.Row="1">
									<StackPanel Spacing="12">
										<TextBox MinHeight="220"
												 AcceptsReturn="True"
												 Text="{Binding MarkdownDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
												 Watermark="在这里输入 Markdown（后续接入渲染引擎）" />
										<ItemsControl ItemsSource="{Binding PreviewBlocks}" ItemTemplate="{StaticResource PreviewBlockTemplate}" />
										<TextBlock IsVisible="{Binding HasPreviewDiagnostic}" Text="{Binding PreviewDiagnostic}" Foreground="#D13438" FontSize="12" />
									</StackPanel>
								</ScrollViewer>
							</Grid>
						</Border>

						<Grid IsVisible="{Binding IsSplitMode}" RowDefinitions="Auto, Auto, *">
							<TextBlock Grid.Row="0" Text="分屏模式：源码 + 预览（骨架）" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
							<WrapPanel Grid.Row="1" Margin="0,0,0,8">
								<TextBlock Text="{Binding SplitOrientationText}" Opacity="0.85" Margin="0,0,12,0"/>
								<TextBlock Text="{Binding ActiveDocumentDisplay, StringFormat=活动文档：{0}}" Opacity="0.85" Margin="0,0,12,0"/>
								<TextBlock Text="{Binding ActiveDocumentDirtyText}" Opacity="0.85" />
							</WrapPanel>

							<Grid Grid.Row="2" IsVisible="{Binding IsSplitHorizontal}" ColumnDefinitions="*,8,*">
								<Border Grid.Column="0" Padding="10" CornerRadius="8" Background="#0FFFFFFF" BorderBrush="#2FFFFFFF" BorderThickness="1">
									<TextBox AcceptsReturn="True"
											 Text="{Binding MarkdownDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
											 CaretIndex="{Binding SplitSourceCaretIndex, Mode=TwoWay}"
											 Watermark="左侧源码区（占位）" />
								</Border>
								<Border Grid.Column="1" Background="Transparent" Width="8" />
								<Border Grid.Column="2" Padding="10" CornerRadius="8" Background="#0FFFFFFF" BorderBrush="#2FFFFFFF" BorderThickness="1">
									<ScrollViewer>
										<StackPanel Spacing="8">
											<ItemsControl ItemsSource="{Binding PreviewBlocks}" ItemTemplate="{StaticResource PreviewBlockTemplate}" />
											<TextBlock IsVisible="{Binding HasPreviewDiagnostic}" Text="{Binding PreviewDiagnostic}" Foreground="#D13438" FontSize="12" />
										</StackPanel>
									</ScrollViewer>
								</Border>
							</Grid>

							<Grid Grid.Row="2" IsVisible="{Binding IsSplitVertical}" RowDefinitions="*,8,*">
								<Border Grid.Row="0" Padding="10" CornerRadius="8" Background="#0FFFFFFF" BorderBrush="#2FFFFFFF" BorderThickness="1">
									<TextBox AcceptsReturn="True"
											 Text="{Binding MarkdownDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
											 CaretIndex="{Binding SplitSourceCaretIndex, Mode=TwoWay}"
											 Watermark="上方源码区（占位）" />
								</Border>
								<Border Grid.Row="1" Background="Transparent" Height="8" />
								<Border Grid.Row="2" Padding="10" CornerRadius="8" Background="#0FFFFFFF" BorderBrush="#2FFFFFFF" BorderThickness="1">
									<ScrollViewer>
										<StackPanel Spacing="8">
											<ItemsControl ItemsSource="{Binding PreviewBlocks}" ItemTemplate="{StaticResource PreviewBlockTemplate}" />
											<TextBlock IsVisible="{Binding HasPreviewDiagnostic}" Text="{Binding PreviewDiagnostic}" Foreground="#D13438" FontSize="12" />
										</StackPanel>
									</ScrollViewer>
								</Border>
							</Grid>
						</Grid>

						<Border IsVisible="{Binding IsReadMode}"
								Padding="16"
								CornerRadius="12"
								Background="#0FFFFFFF"
								BorderBrush="#2FFFFFFF"
								BorderThickness="1">
							<Grid RowDefinitions="Auto, *">
								<TextBlock Grid.Row="0" Text="阅读模式：只读渲染（骨架）" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
								<ScrollViewer Grid.Row="1">
									<StackPanel Spacing="8">
										<TextBlock TextWrapping="Wrap" Text="{Binding PreviewPlaceholder}" />
										<TextBlock IsVisible="{Binding HasPreviewDiagnostic}" Text="{Binding PreviewDiagnostic}" Foreground="#D13438" FontSize="12" />
									</StackPanel>
								</ScrollViewer>
							</Grid>
						</Border>
					</Panel>
				</StackPanel>
			</Border>
		</Grid>
	</DockPanel>
</UserControl>
