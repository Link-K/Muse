<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- General brushes for file tree and tabs -->
  <SolidColorBrush x:Key="TreeBackground" Color="#0FFFFFFF" />
  <SolidColorBrush x:Key="TreeForeground" Color="#E6E6E6" />
  <SolidColorBrush x:Key="IconForeground" Color="#9AA0A6" />

  <!-- Icon font family and glyphs -->
  <x:String x:Key="IconFontFamily">Segoe MDL2 Assets</x:String>
  <x:String x:Key="TabDirtyGlyph">●</x:String>
  <x:String x:Key="TabConflictGlyph">⚠</x:String>
  <x:String x:Key="TabCloseGlyph">✕</x:String>
  <x:String x:Key="ExpandCollapsedGlyph">▸</x:String>
  <x:String x:Key="ExpandExpandedGlyph">▾</x:String>
  <!-- Tree item backgrounds and states -->
  <SolidColorBrush x:Key="TreeItemHoverBackground" Color="#0AFFFFFF" />
  <SolidColorBrush x:Key="TreeItemSelectedBackground" Color="#14FFFFFF" />

  <!-- Icon sizing -->
  <x:Double x:Key="IconLargeSize">14</x:Double>
  <x:Double x:Key="IconSmallSize">12</x:Double>

  <!-- Note: Styles should be applied in App or Views; ThemeResources contains brushes/glyphs only -->

  <!-- Tab icon brushes -->
  <SolidColorBrush x:Key="TabDirtyForeground" Color="#D13438" />
  <SolidColorBrush x:Key="TabConflictForeground" Color="#D13438" />

</ResourceDictionary>
