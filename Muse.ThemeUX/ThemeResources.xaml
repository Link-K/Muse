<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- General brushes for file tree and tabs -->
  <SolidColorBrush x:Key="TreeBackground" Color="#0FFFFFFF" />
  <SolidColorBrush x:Key="TreeForeground" Color="#E6E6E6" />
  <SolidColorBrush x:Key="IconForeground" Color="#9AA0A6" />

  <!-- Icon font family and glyphs -->
  <FontFamily x:Key="IconFontFamily">Segoe MDL2 Assets</FontFamily>
  <!-- Use explicit Unicode codepoints for clarity and consistent rendering -->
  <x:String x:Key="TabDirtyGlyph">&#x25CF;</x:String> <!-- Black Circle -->
  <x:String x:Key="TabConflictGlyph">&#x26A0;</x:String> <!-- Warning Sign -->
  <x:String x:Key="TabCloseGlyph">&#x2715;</x:String> <!-- Multiplication X -->
  <x:String x:Key="OpenGlyph">&#x2913;</x:String> <!-- Downwards Arrow With Tip Leftwards -->
  <x:String x:Key="ExpandCollapsedGlyph">&#x25B8;</x:String> <!-- Small Right-Pointing Triangle -->
  <x:String x:Key="ExpandExpandedGlyph">&#x25BE;</x:String> <!-- Small Down-Pointing Triangle -->
  <!-- Tree item backgrounds and states -->
  <SolidColorBrush x:Key="TreeItemHoverBackground" Color="#0AFFFFFF" />
  <SolidColorBrush x:Key="TreeItemSelectedBackground" Color="#14FFFFFF" />

  <!-- Icon sizing -->
  <x:Double x:Key="IconLargeSize">14</x:Double>
  <x:Double x:Key="IconSmallSize">12</x:Double>

  <!-- Note: Styles should be applied in App or Views; ThemeResources contains brushes/glyphs only -->

  <!-- Tab icon brushes -->
  <SolidColorBrush x:Key="TabDirtyForeground" Color="#D13438" />
  <SolidColorBrush x:Key="TabConflictForeground" Color="#D13438" />

  <!-- Shared control styles are provided separately in ThemeStyles.xaml -->

</ResourceDictionary>
